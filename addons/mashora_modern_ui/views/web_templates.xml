<?xml version="1.0" encoding="utf-8"?>
<mashora>

    <template id="mashora_modern_ui_webclient_bootstrap" inherit_id="web.webclient_bootstrap">
        <xpath expr="//meta[@name='theme-color']" position="attributes">
            <attribute name="content">#0f1729</attribute>
        </xpath>
        <xpath expr="//t[@t-set='body_classname']" position="attributes">
            <attribute name="t-value">'o_web_client o_mashora_modern_ui'</attribute>
        </xpath>
    </template>

    <template id="mashora_modern_ui_login_layout" inherit_id="web.login_layout">
        <xpath expr="//t[@t-set='body_classname']" position="attributes">
            <attribute name="t-value">'bg-100 o_mashora_auth'</attribute>
        </xpath>
        <xpath expr="//div[hasclass('container', 'py-5')]" position="replace">
            <div class="msh_auth_shell">
                <div class="msh_auth_story">
                    <div class="msh_auth_brand">
                        <span class="msh_auth_brand_mark">M</span>
                        <div>
                            <span class="msh_auth_brand_title">Mashora</span>
                            <span class="msh_auth_brand_subtitle">Business command center</span>
                        </div>
                    </div>
                    <div class="msh_auth_copy">
                        <span class="msh_auth_eyebrow">Modern workspace</span>
                        <h1>Run CRM, operations, and growth from one polished system.</h1>
                        <p>
                            Faster navigation, cleaner data views, and a stronger first impression for every team that signs in.
                        </p>
                    </div>
                    <div class="msh_auth_metric_grid">
                        <div class="msh_auth_metric">
                            <strong>Unified</strong>
                            <span>Sales, service, settings, and operations in one place.</span>
                        </div>
                        <div class="msh_auth_metric">
                            <strong>Faster</strong>
                            <span>A lighter landing experience with less heavy UI work on first load.</span>
                        </div>
                        <div class="msh_auth_metric">
                            <strong>Sharper</strong>
                            <span>Executive-grade cards, navigation, and forms built for business teams.</span>
                        </div>
                    </div>
                </div>

                <div class="msh_auth_panel">
                    <div t-attf-class="card border-0 mx-auto {{login_card_classes}} o_database_list msh_auth_card">
                        <div class="card-body">
                            <div class="msh_auth_card_intro">
                                <span class="msh_auth_card_eyebrow">Secure access</span>
                                <h2>Welcome back</h2>
                                <p>Sign in to open your workspace and continue where your team left off.</p>
                            </div>
                            <div class="text-center pb-3 border-bottom mb-4">
                                <img t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}" alt="Logo" style="max-height:96px; max-width: 100%; width:auto"/>
                            </div>
                            <t t-out="0"/>
                            <div class="text-center small mt-4 pt-3 border-top" t-if="not disable_footer">
                                <t t-if="not disable_database_manager">
                                    <a class="border-end pe-2 me-1" href="/web/database/manager">Manage Databases</a>
                                </t>
                                <a href="https://www.mashora.com?utm_source=db&amp;utm_medium=auth" target="_blank">Powered by <span>Mashora</span></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

</mashora>
