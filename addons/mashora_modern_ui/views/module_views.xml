<?xml version="1.0" encoding="utf-8"?>
<mashora>
    <data>
        <record id="mashora_module_view_kanban_ui" model="ir.ui.view">
            <field name="name">ir.module.module.view.kanban.mashora.ui</field>
            <field name="model">ir.module.module</field>
            <field name="inherit_id" ref="base.module_view_kanban"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <xpath expr="//kanban" position="attributes">
                    <attribute name="class" add="msh_market_kanban" separator=" "/>
                </xpath>
                <xpath expr="//field[@name='application']" position="after">
                    <field name="category_id"/>
                    <field name="author"/>
                </xpath>
                <xpath expr="//t[@t-name='card']/aside" position="attributes">
                    <attribute name="class">msh_market_card_media</attribute>
                </xpath>
                <xpath expr="//t[@t-name='card']/main" position="attributes">
                    <attribute name="class">msh_market_card_body</attribute>
                </xpath>
                <xpath expr="//t[@t-name='card']/main/field[@name='shortdesc']" position="before">
                    <div class="msh_market_card_head">
                        <div class="msh_market_category" t-if="record.category_id.raw_value">
                            <field name="category_id"/>
                        </div>
                        <div t-att-class="'msh_market_state ' + (record.state.raw_value === 'installed' ? 'is-live' : (record.to_buy.raw_value ? 'is-premium' : 'is-ready'))">
                            <t t-if="record.state.raw_value == 'installed'">Live</t>
                            <t t-elif="record.to_buy.raw_value">Premium</t>
                            <t t-else="">Ready</t>
                        </div>
                    </div>
                </xpath>
                <xpath expr="//t[@t-name='card']/main/p" position="replace">
                    <div class="msh_market_summary">
                        <field groups="!base.group_no_one" name="summary"/>
                        <code groups="base.group_no_one"><field name="name"/></code>
                    </div>
                    <div class="msh_market_meta">
                        <span class="msh_market_meta_item">
                            <i class="fa fa-cube"/>
                            <field name="name"/>
                        </span>
                        <span class="msh_market_meta_item" t-if="record.author.raw_value">
                            <i class="fa fa-user"/>
                            <field name="author"/>
                        </span>
                    </div>
                </xpath>
                <xpath expr="//t[@t-name='card']/main/footer" position="attributes">
                    <attribute name="class">msh_market_card_footer</attribute>
                </xpath>
            </field>
        </record>
    </data>
</mashora>
