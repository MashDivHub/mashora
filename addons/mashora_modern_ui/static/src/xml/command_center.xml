<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mashora_modern_ui.CommandCenter">
        <div class="msh_command_center">
            <Layout display="display" className="'msh_command_center_layout overflow-auto'">
                <t t-set-slot="control-panel-create-button">
                    <button class="btn btn-primary msh_cp_primary" t-on-click="openAppsCatalog">
                        <i class="fa fa-th-large me-2"/>
                        Open App Store
                    </button>
                </t>
                <t t-set-slot="layout-buttons">
                    <button class="btn btn-secondary" t-on-click="openSettings">
                        Settings
                    </button>
                    <button class="btn btn-secondary" t-on-click="openUsers">
                        Users
                    </button>
                </t>
                <t t-set-slot="control-panel-navigation-additional">
                    <span class="msh_cp_status badge text-bg-light border" t-esc="statusLabel"/>
                </t>

                <div class="container-fluid msh_command_center_page">
                    <section class="msh_hero_card">
                        <div class="msh_hero_copy">
                            <span class="msh_eyebrow">Business cockpit</span>
                            <h1><t t-esc="greeting"/>. Your workspace is ready for CRM, operations, and growth.</h1>
                            <p>
                                Launch applications, review system readiness, and guide your team from a faster,
                                cleaner command center.
                            </p>
                            <div class="msh_hero_actions">
                                <button class="btn btn-primary" t-on-click="openAppsCatalog">
                                    Browse apps
                                </button>
                                <button class="btn btn-outline-secondary" t-on-click="openCompanies">
                                    Companies
                                </button>
                            </div>
                        </div>
                        <div class="msh_hero_stats">
                            <div class="msh_hero_stat">
                                <span>Live workspaces</span>
                                <strong t-esc="state.isLoading ? '...' : state.apps.length"/>
                            </div>
                            <div class="msh_hero_stat">
                                <span>Menus available</span>
                                <strong t-esc="state.menuCount"/>
                            </div>
                            <div class="msh_hero_stat">
                                <span>Installed modules</span>
                                <strong t-esc="state.installedModulesCount"/>
                            </div>
                        </div>
                    </section>

                    <div t-if="state.loadError" class="msh_notice_bar">
                        <i class="fa fa-shield me-2"/>
                        <span t-esc="state.loadError"/>
                    </div>

                    <section class="msh_metrics_grid">
                        <article t-foreach="state.metrics" t-as="metric" t-key="metric.label" class="msh_metric_card" t-att-class="'tone-' + metric.tone">
                            <div class="msh_metric_icon">
                                <i t-att-class="'fa ' + metric.icon"/>
                            </div>
                            <div class="msh_metric_value" t-esc="metric.value"/>
                            <div class="msh_metric_label" t-esc="metric.label"/>
                        </article>
                    </section>

                    <section class="msh_dashboard_grid">
                        <article class="msh_panel">
                            <div class="msh_panel_head">
                                <div>
                                    <span class="msh_panel_eyebrow">Installed workspaces</span>
                                    <h3>Launch your apps</h3>
                                </div>
                                <button class="btn btn-link" t-on-click="openAppsCatalog">Open catalog</button>
                            </div>
                            <div t-if="state.isLoading" class="msh_empty_panel">
                                Loading your workspace catalog and live business metrics...
                            </div>
                            <div t-elif="state.apps.length" class="msh_workspace_grid">
                                <button
                                    t-foreach="state.apps"
                                    t-as="app"
                                    t-key="app.id"
                                    class="msh_workspace_card"
                                    t-on-click="() => this.launchApp(app)"
                                >
                                    <span class="msh_workspace_icon">
                                        <img t-if="app.webIconData" t-attf-src="{{app.webIconData}}" t-att-alt="app.name"/>
                                        <span t-else="" t-esc="app.name[0]"/>
                                    </span>
                                    <strong t-esc="app.name"/>
                                    <span t-esc="app.sectionCount + ' sections ready'"/>
                                </button>
                            </div>
                            <div t-else="" class="msh_empty_panel">
                                Install your first business app to turn this shell into a fully operational workspace.
                            </div>
                        </article>

                        <article class="msh_panel">
                            <div class="msh_panel_head">
                                <div>
                                    <span class="msh_panel_eyebrow">Business stack</span>
                                    <h3>Core capability readiness</h3>
                                </div>
                            </div>
                            <div class="msh_module_list">
                                <div t-foreach="state.businessModules" t-as="module" t-key="module.name" class="msh_module_card">
                                    <div class="msh_module_meta">
                                        <span class="msh_module_icon">
                                            <i t-att-class="'fa ' + module.icon"/>
                                        </span>
                                        <div>
                                            <strong t-esc="module.label"/>
                                            <p t-esc="module.description"/>
                                        </div>
                                    </div>
                                    <div class="msh_module_state">
                                        <span class="msh_state_badge" t-att-class="module.installed ? 'is-live' : 'is-ready'" t-esc="module.stateLabel"/>
                                        <strong t-if="module.count !== null" t-esc="module.count"/>
                                        <button t-if="not module.installed and not state.isLoading" class="btn btn-link p-0" t-on-click="openAppsCatalog">
                                            Install
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </article>

                        <article class="msh_panel">
                            <div class="msh_panel_head">
                                <div>
                                    <span class="msh_panel_eyebrow">Operational shortcuts</span>
                                    <h3>Keep admins moving</h3>
                                </div>
                            </div>
                            <div class="msh_shortcut_list">
                                <button class="msh_shortcut_card" t-on-click="openUsers">
                                    <strong>Manage users</strong>
                                    <span>Provision access, roles, and internal teams.</span>
                                </button>
                                <button class="msh_shortcut_card" t-on-click="openCompanies">
                                    <strong>Company setup</strong>
                                    <span>Maintain business entities, branding, and document settings.</span>
                                </button>
                                <button class="msh_shortcut_card" t-on-click="openSettings">
                                    <strong>Platform settings</strong>
                                    <span>Review system configuration without loading it by default.</span>
                                </button>
                                <button class="msh_shortcut_card" t-on-click="openAppsCatalog">
                                    <strong>Expand the stack</strong>
                                    <span>Add CRM, Sales, Contacts, and other business capabilities.</span>
                                </button>
                            </div>
                        </article>
                    </section>
                </div>
            </Layout>
        </div>
    </t>

</templates>
