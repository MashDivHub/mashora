# Mashora ERP Backend Configuration
# Copy to .env and adjust values

# App
APP_NAME=Mashora ERP API
DEBUG=false

# Mashora ORM
MASHORA_DB_NAME=mashora
MASHORA_DB_HOST=postgres
MASHORA_DB_PORT=5432
MASHORA_DB_USER=mashora
MASHORA_DB_PASSWORD=mashora_secret
MASHORA_DB_MAXCONN=16
MASHORA_ROOT_PATH=/opt/mashora
MASHORA_ADDONS_PATH=/opt/mashora/addons

# JWT Auth
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Server
HOST=0.0.0.0
PORT=8001
ORM_THREAD_POOL_SIZE=8
ORM_REQUEST_TIMEOUT=30
