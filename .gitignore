# =============================================
# Mashora Monorepo — .gitignore
# =============================================

# Python
*.py[co]
__pycache__/
*.egg-info
*.egg
.venv/
venv/
env/

# Node
node_modules/
dist/
.turbo/

# IDE
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Environment & secrets
.env
.env.*
!.env.example

# Build artifacts
/build/
/bin/
/lib/
/include/
/share/

# App (ERP) build outputs
/app/frontend/dist/
/app/backend/__pycache__/

# Portal build outputs
/portal/frontend/dist/
/portal/backend/__pycache__/

# Packages build outputs
/packages/*/dist/

# Logs
*.log
*.err.log

# omc internal
.omc/
